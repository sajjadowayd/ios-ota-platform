# ─── Backend  (copy to backend/.env) ─────────────────────────────────────────

# PostgreSQL connection string
# Default local credentials (postgres / postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ota_db

# Secret used to sign JWT tokens — change this to a long random string
JWT_SECRET=change-me-to-a-long-random-secret

# Admin panel credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Public base URL of the backend — used to build manifest.plist URLs
# For local dev:
BASE_URL=http://localhost:3001
# For HTTPS testing via Cloudflare Tunnel or ngrok, replace with tunnel URL:
# BASE_URL=https://your-tunnel-url.trycloudflare.com

# Port the backend listens on
PORT=3001

# Allowed CORS origins (comma-separated)
CORS_ORIGIN=http://localhost:3000

# Encryption key for certificate passwords (64-char hex string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If left empty, a key will be derived from JWT_SECRET
ENCRYPTION_KEY=


# ─── Frontend  (copy to frontend/.env.local) ──────────────────────────────────

# Public URL of the backend API — used by the browser (client-side)
# For local dev:
NEXT_PUBLIC_API_URL=http://localhost:3001
# For HTTPS testing via Cloudflare Tunnel or ngrok:
# NEXT_PUBLIC_API_URL=https://your-tunnel-url.trycloudflare.com


# ─── HTTPS Tunnel options ─────────────────────────────────────────────────────
#
# Apple OTA installation requires HTTPS for the manifest URL.
# Use one of these methods during local development:
#
# 1. Cloudflare Quick Tunnel (recommended — no account needed):
#    cloudflared tunnel --url http://localhost:3001
#
# 2. ngrok (stable URL per session — free account required):
#    ngrok http 3001
#
# 3. localhost.run (no install — SSH only):
#    ssh -R 80:localhost:3001 nokey@localhost.run
#
# After starting a tunnel, update BASE_URL and NEXT_PUBLIC_API_URL above
# with the HTTPS URL provided by the tunnel.
